@page "/"
@rendermode InteractiveServer
@implements IDisposable
@inject ModService Service
@inject ServerConfig Server
@using System.Net
@using System.Text

<div class="head">
    <h1>MC Mod Manager</h1>
    <nav class="tabs">
        <button class="tab @(_tab == Tab.Mods ? "on" : "")" disabled="@_busy" @onclick="() => _tab = Tab.Mods">Local mods</button>
        <button class="tab @(_tab == Tab.Server ? "on" : "")" disabled="@_busy" @onclick="ShowServer">Server</button>
    </nav>
</div>

@if (_tab == Tab.Mods)
{
    <section class="actions">
        <div class="group">
            <button class="btn" disabled="@_busy" @onclick="Refresh">↻ Refresh / Scan</button>
        </div>
        <span class="sep"></span>
        <div class="stats">
            <button class="chip @(NoFilter ? "on" : "")" @onclick="ShowAll">
                <span class="n">@Service.Mods.Count</span> total
            </button>
            <button class="chip @(_installedOnly ? "on" : "")" @onclick="() => Toggle(ref _installedOnly)">
                <span class="n">@InstalledCount</span> installed
            </button>
            <button class="chip danger @(_problemsOnly ? "on" : "")" @onclick="() => Toggle(ref _problemsOnly)">
                <span class="n">@ProblemCount</span> problems
            </button>
            @if (Service.Unassigned.Count > 0)
            {
                <span class="chip warn"><span class="n">@Service.Unassigned.Count</span> unassigned</span>
            }
        </div>
    </section>
}

@if (_tab == Tab.Server)
{
<section class="actions">
    <div class="group">
        <button class="btn" disabled="@_busy" @onclick="Refresh">↻ Refresh / Scan</button>
    </div>
    <span class="sep"></span>
    <div class="group">
        <span class="server @ServerState" title="@ServerTitle">
            <span class="led"></span> Server @ServerLabel
        </span>
        <button class="btn primary" disabled="@(_busy || !Online || TotalDiff == 0)" @onclick="Sync">
            Sync@(TotalDiff > 0 ? $" ({TotalDiff})" : "")
        </button>
    </div>
    @if (_progress is { } prog)
    {
        <div class="progress" title="@prog.Label/@prog.File">
            <div class="bar"><div class="fill" style="width:@prog.Percent%"></div></div>
            <span class="ptext">
                <strong>@prog.Done / @prog.Total</strong>
                @if (!string.IsNullOrEmpty(prog.File))
                {
                    <span class="pfile">@(prog.Kind == DeltaKind.Remove ? "removing" : "uploading") @prog.Label/@prog.File</span>
                }
            </span>
        </div>
    }
    else
    {
        @if (Online && _sync!.Forge is { } forge)
        {
            @if (forge.Match)
            {
                <span class="chip static" title="local and server run the same Forge">Forge @forge.Local ✓</span>
            }
            else if (forge.Known)
            {
                <span class="chip bad" title="server runs a different Forge — fix it before syncing mods">
                    ⚠ Forge: you @forge.Local · server @forge.Remote
                </span>
            }
            else if (forge.Local is not null && forge.Remote is null)
            {
                <span class="chip bad" title="no Forge found on the server">⚠ Forge @forge.Local · server: none</span>
            }
        }
        @if (Online)
        {
            <span class="glabel">@(TotalDiff == 0 ? "✓ up to date" : $"{TotalDiff} file{(TotalDiff == 1 ? "" : "s")} to sync")</span>
        }
    }
</section>

@if (!ServerReady)
{
    <p class="hint">Server not configured — set <code>BasePath</code> (the Minecraft server folder on the host) and <code>Username</code> under <code>App:Sftp</code> or <code>App:Ftp</code> in appsettings/user-secrets.</p>
}

@if (Online)
{
    <section class="diff">
        @{ var gi = 0; }
        @foreach (var t in _sync!.Targets)
        {
            <div class="tgroup @(t.Total == 0 ? "clean" : "")">
                <div class="tgroup-head">
                    <strong>@t.Label</strong>
                    <span class="srv-count" title="files currently on the server">@t.RemoteCount on server</span>
                    @if (t.Adds > 0) { <span class="tag add">+@t.Adds new</span> }
                    @if (t.Changes > 0) { <span class="tag change">~@t.Changes changed</span> }
                    @if (t.Removes > 0) { <span class="tag remove">−@t.Removes remove</span> }
                    @if (t.Total == 0) { <span class="tag ok">✓ in sync</span> }
                </div>
                @if (t.Total > 0)
                {
                    <ul class="flist">
                        @foreach (var d in t.Deltas)
                        {
                            var idx = gi;
                            gi++;
                            <li class="frow @KindCss(d.Kind) @RowState(idx)">
                                <span class="fglyph">@Glyph(idx, d.Kind)</span>
                                <span class="fpath">@d.RelativePath</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        }
    </section>
}

<ServerControlPanel />
}

@if (_tab == Tab.Mods)
{
<datalist id="mod-ids">
    @foreach (var id in ModIds)
    {
        <option value="@id"></option>
    }
</datalist>
<datalist id="mod-files">
    @foreach (var file in ModFiles)
    {
        <option value="@file"></option>
    }
</datalist>

@if (Service.Unassigned.Count > 0)
{
    <section class="unassigned">
        <div class="head-row">
            <h2>⚠ Unassigned files</h2>
            <span class="chip warn static"><span class="n">@Service.Unassigned.Count</span></span>
        </div>
        <p class="hint">Jars present in the folder that no mod claims yet. Pick an existing mod id or type a new one.</p>
        @foreach (var file in Service.Unassigned)
        {
            <div class="assign-row">
                <span class="fname">@file</span>
                <input list="mod-ids" placeholder="mod id…"
                       value="@_assign.GetValueOrDefault(file, "")"
                       @oninput="e => _assign[file] = e.Value?.ToString() ?? string.Empty" />
                <button class="btn tiny primary" disabled="@_busy" @onclick="() => Assign(file)">assign →</button>
            </div>
        }
    </section>
}

<div class="count-bar">showing @Filtered.Count() of @Service.Mods.Count mods</div>

<div class="mods-wrap">
<table class="mods">
    <thead>
        <tr>
            <th class="c-exp"></th>
            <th>
                <div class="th-filter">
                    <span>Mod</span>
                    <div class="search-wrap">
                        <input class="search-mini" placeholder="🔍 search id / desc / file…" @bind="_search" @bind:event="oninput" />
                        @if (!string.IsNullOrEmpty(_search))
                        {
                            <button class="clear-x" @onclick='() => _search = ""' title="clear">✕</button>
                        }
                    </div>
                </div>
            </th>
            <th>
                <div class="th-filter">
                    <span>Priority</span>
                    <select class="filter @(_prioFilter is not null ? "active" : "")" @bind="_prioFilter">
                        <option value="">All</option>
                        @foreach (var p in Enum.GetValues<Priority>())
                        {
                            <option value="@p">@p</option>
                        }
                    </select>
                </div>
            </th>
            <th>
                <div class="th-filter">
                    <span>Category</span>
                    <select class="filter @(_catFilter is not null ? "active" : "")" @bind="_catFilter">
                        <option value="">All</option>
                        @foreach (var c in Enum.GetValues<Category>())
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                </div>
            </th>
            <th>
                <div class="th-filter">
                    <span>Works</span>
                    <select class="filter @(_worksFilter != Tri.All ? "active" : "")" @bind="_worksFilter">
                        <option value="@Tri.All">All</option>
                        <option value="@Tri.Yes">Yes</option>
                        <option value="@Tri.No">No</option>
                    </select>
                </div>
            </th>
            <th>
                <div class="th-filter">
                    <span>Configured</span>
                    <select class="filter @(_configuredFilter != Tri.All ? "active" : "")" @bind="_configuredFilter">
                        <option value="@Tri.All">All</option>
                        <option value="@Tri.Yes">Yes</option>
                        <option value="@Tri.No">No</option>
                    </select>
                </div>
            </th>
            <th>Description</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var mod in Filtered)
        {
            var missing = Service.MissingDependencies(mod).ToList();
            var floating = Service.IsFloating(mod);
            var problem = missing.Count > 0 || floating;
            var open = IsExpanded(mod);
            <tr class="@RowClass(mod, problem)">
                <td class="c-exp">
                    <button class="exp @(open ? "open" : "")" @onclick="() => ToggleExpand(mod)"
                            title="@(open ? "collapse" : "expand")">@(open ? "▾" : "▸")</button>
                    <span class="dot" title="@(mod.Installed ? mod.FileName : "not installed")"></span>
                </td>
                <td class="id-cell">
                    @EditableText(mod.Id, $"i:{mod.Id}", v => RenameId(mod, v), "id", "id…")
                    @if (missing.Count > 0)
                    {
                        <span class="badge" title="missing: @string.Join(", ", missing)">missing dep</span>
                    }
                    @if (floating)
                    {
                        <span class="badge" title="nothing installed depends on this">floating</span>
                    }
                </td>
                <td>
                    <select class="pill prio-@mod.Priority" @bind="mod.Priority" @bind:after="Save">
                        @foreach (var p in Enum.GetValues<Priority>())
                        {
                            <option value="@p">@p</option>
                        }
                    </select>
                </td>
                <td>
                    <select class="pill cat-@mod.Category" @bind="mod.Category" @bind:after="Save">
                        @foreach (var c in Enum.GetValues<Category>())
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                </td>
                <td class="c-check">
                    @if (mod.Installed)
                    {
                        <input type="checkbox" class="chk" checked="@mod.Works"
                               @onchange="e => SetWorks(mod, (bool)(e.Value ?? false))" />
                    }
                </td>
                <td class="c-check">
                    @if (mod.Installed)
                    {
                        <input type="checkbox" class="chk" checked="@mod.Configured"
                               @onchange="e => SetConfigured(mod, (bool)(e.Value ?? false))" />
                    }
                </td>
                <td>@EditableText(mod.Description, $"d:{mod.Id}", v => { mod.Description = v; Save(); }, "desc", "—")</td>
                <td><button class="btn tiny danger" disabled="@_busy" @onclick="() => Delete(mod)" title="remove from db">✕</button></td>
            </tr>
            @if (open)
            {
                <tr class="detail-row">
                    <td></td>
                    <td colspan="7">
                        <div class="detail">
                            <div class="detail-col">
                                <div class="detail-h">Filename</div>
                                <div class="line">
                                    <span class="dot-mini @(mod.Installed ? "on" : "")"
                                          title="@(mod.Installed ? "present in folder" : "not present")"></span>
                                    @EditableText(mod.FileName, $"f:{mod.Id}", v => SetFileName(mod, v), "mono grow", "filename…", "mod-files")
                                </div>
                            </div>
                            <div class="detail-col">
                                <div class="detail-h">Dependencies <span class="cnt">@mod.Dependencies.Count</span></div>
                                @for (var i = 0; i < mod.Dependencies.Count; i++)
                                {
                                    var idx = i;
                                    var dep = mod.Dependencies[idx];
                                    var present = Service.IsPresent(dep);
                                    <div class="line">
                                        <span class="dot-mini @(present ? "on" : (mod.Installed ? "bad" : ""))"
                                              title="@DepTitle(mod, present)"></span>
                                        @EditableText(dep, $"p:{mod.Id}:{idx}", v => SetDep(mod, idx, v), "mono grow", "filename…", "mod-files")
                                        <button class="x" @onclick="() => RemoveDep(mod, idx)" title="remove">✕</button>
                                    </div>
                                }
                                <div class="line add">
                                    <input class="ghost mono grow" list="mod-files" placeholder="+ add dependency…"
                                           value="@_draftDep.GetValueOrDefault(mod.Id, "")"
                                           @oninput="e => _draftDep[mod.Id] = e.Value?.ToString() ?? string.Empty"
                                           @onkeydown='e => { if (e.Key == "Enter") AddDep(mod); }' />
                                    <button class="x add-btn" @onclick="() => AddDep(mod)" title="add">＋</button>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        }
        @if (!Filtered.Any())
        {
            <tr><td colspan="8" class="empty">No mods match the current filters.</td></tr>
        }
    </tbody>
</table>
</div>
}

<section class="log">
    <div class="log-head">
        <strong>Output</strong>
        <button class="btn tiny" @onclick="() => _log.Clear()">clear</button>
        @if (_busy)
        {
            <span class="spinner">working…</span>
        }
    </div>
    <pre>@foreach (var e in _log)
{<span style="color:@Css(e.Color)">@e.Message</span>}</pre>
</section>

@code {
    private readonly List<LogEntry> _log = new();
    private readonly Dictionary<string, string> _assign = new();
    private readonly Dictionary<string, string> _draftDep = new();
    // explicit user choice per mod id (true=open, false=collapsed); absent = follow auto-expand
    private readonly Dictionary<string, bool> _manual = new(StringComparer.OrdinalIgnoreCase);

    private string _search = "";
    private Category? _catFilter;
    private Priority? _prioFilter;
    private Tri _worksFilter = Tri.All;
    private Tri _configuredFilter = Tri.All;
    private bool _installedOnly;
    private bool _problemsOnly;
    private bool _busy;

    // tri-state column filter: ignore / must be true / must be false
    private enum Tri { All, Yes, No }
    private static bool TriMatch(Tri f, bool value) => f switch
    {
        Tri.Yes => value,
        Tri.No => !value,
        _ => true,
    };

    // the single field currently in edit mode (click-to-edit), so the rest stay highlightable text
    private string? _editing;
    private ElementReference _editRef;
    private bool _focusNext;

    private enum Tab { Mods, Server }
    private Tab _tab = Tab.Mods;

    // non-null while a sync is uploading, drives the progress bar
    private SyncProgress? _progress;

    // result of the last diff/sync attempt; null until we've checked the server
    private SyncResult? _sync;
    private int TotalDiff => _sync?.Total ?? 0;

    private bool ServerReady => Server.Ready;       // enough config to attempt a connection
    private bool Online => _sync is { Ok: true };   // last attempt actually reached the server

    private string ServerState =>
        !ServerReady ? "" :
        Online ? "on" :
        _sync is { Ok: false } ? "off" : "";

    private string ServerLabel =>
        !ServerReady ? "not set" :
        _busy && _sync is null ? "checking…" :
        Online ? "On" :
        _sync is { Ok: false } ? "Off" : "?";

    // live per-file state during a sync: rows before the cursor are done, the cursor is uploading, the rest pending.
    // the flat row index matches SyncAll's order (targets in order, deltas in order), which is what progress reports.
    private string RowState(int idx)
    {
        if (_progress is null) return "todo";          // showing a diff, not syncing
        if (idx < _progress.Done) return "done";
        if (idx == _progress.Done) return "active";
        return "pending";
    }

    private string Glyph(int idx, DeltaKind kind) => RowState(idx) switch
    {
        "done" => "✓",
        "active" => "↑",
        _ => kind switch { DeltaKind.Add => "+", DeltaKind.Change => "~", DeltaKind.Remove => "−", _ => "•" },
    };

    private static string KindCss(DeltaKind kind) => kind switch
    {
        DeltaKind.Add => "add",
        DeltaKind.Change => "change",
        DeltaKind.Remove => "remove",
        _ => "",
    };

    private string ServerTitle =>
        !ServerReady ? "no server configured" :
        Online ? $"{Server.Kind} {Server.Username}@{Server.Host} — reachable" :
        _sync is { Ok: false } ? $"cannot reach {Server.Kind} {Server.Host}: {_sync.Error}" :
        $"{Server.Kind} {Server.Host} — not checked yet";

    private bool NoFilter => !_installedOnly && !_problemsOnly;
    private int InstalledCount => Service.Mods.Count(m => m.Installed);
    private int ProblemCount => Service.Mods.Count(HasProblem);

    private IEnumerable<string> ModIds => Service.Mods
        .Select(m => m.Id)
        .OrderBy(id => id, StringComparer.OrdinalIgnoreCase);

    private IEnumerable<string> ModFiles => Service.Mods
        .Select(m => m.FileName)
        .Where(f => !string.IsNullOrEmpty(f))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(f => f, StringComparer.OrdinalIgnoreCase);

    private bool HasProblem(Mod mod) =>
        Service.MissingDependencies(mod).Any() || Service.IsFloating(mod);

    private void ShowAll() { _installedOnly = false; _problemsOnly = false; }
    private void Toggle(ref bool flag) => flag = !flag;

    private IEnumerable<Mod> Filtered => Service.Mods
        .Where(m => !_installedOnly || m.Installed)
        .Where(m => !_problemsOnly || HasProblem(m))
        .Where(m => _catFilter is null || m.Category == _catFilter)
        .Where(m => _prioFilter is null || m.Priority == _prioFilter)
        .Where(m => TriMatch(_worksFilter, m.Works))
        .Where(m => TriMatch(_configuredFilter, m.Configured))
        .Where(Matches)
        .OrderBy(m => m.Id, StringComparer.OrdinalIgnoreCase);

    private bool Matches(Mod m) => string.IsNullOrWhiteSpace(_search)
        || m.Id.Contains(_search, StringComparison.OrdinalIgnoreCase)
        || m.Description.Contains(_search, StringComparison.OrdinalIgnoreCase)
        || m.FileName.Contains(_search, StringComparison.OrdinalIgnoreCase)
        || m.Dependencies.Any(d => d.Contains(_search, StringComparison.OrdinalIgnoreCase));

    // a manual open/collapse always wins; otherwise auto-expand when the match hides in the detail
    private bool IsExpanded(Mod m) =>
        _manual.TryGetValue(m.Id, out var open) ? open : AutoExpand(m);

    // auto-expand only when the search hits a hidden field AND nothing visible (id/description)
    private bool AutoExpand(Mod m)
    {
        if (string.IsNullOrWhiteSpace(_search))
            return false;

        var visible = m.Id.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || m.Description.Contains(_search, StringComparison.OrdinalIgnoreCase);
        if (visible)
            return false;

        return m.FileName.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || m.Dependencies.Any(d => d.Contains(_search, StringComparison.OrdinalIgnoreCase));
    }

    private void ToggleExpand(Mod m) => _manual[m.Id] = !IsExpanded(m);

    private static string DepTitle(Mod mod, bool present)
    {
        if (present) return "dependency present in folder";
        if (mod.Installed) return "MISSING — required but not present";
        return "not present";
    }

    // ── click-to-edit field: highlighted text until clicked, input while editing ──
    private RenderFragment EditableText(string value, string key, Action<string> commit,
        string css, string placeholder, string? listId = null) => @<span class="ed">
        @if (_editing == key)
        {
            <input @ref="_editRef" class="ghost @css" value="@value" list="@listId"
                   @onchange="e => { commit(e.Value?.ToString() ?? string.Empty); _editing = null; }"
                   @onblur="() => _editing = null"
                   @onkeydown='e => { if (e.Key == "Enter" || e.Key == "Escape") _editing = null; }' />
        }
        else
        {
            <span class="editable @css" @onclick="() => StartEdit(key)">@RenderValue(value, placeholder)</span>
        }
    </span>;

    private MarkupString RenderValue(string value, string placeholder) =>
        string.IsNullOrEmpty(value)
            ? (MarkupString)$"<span class=\"ph\">{WebUtility.HtmlEncode(placeholder)}</span>"
            : Highlight(value);

    private MarkupString Highlight(string text)
    {
        var term = _search;
        if (string.IsNullOrWhiteSpace(term))
            return (MarkupString)WebUtility.HtmlEncode(text);

        var sb = new StringBuilder();
        var i = 0;
        while (i < text.Length)
        {
            var idx = text.IndexOf(term, i, StringComparison.OrdinalIgnoreCase);
            if (idx < 0)
            {
                sb.Append(WebUtility.HtmlEncode(text[i..]));
                break;
            }
            sb.Append(WebUtility.HtmlEncode(text[i..idx]));
            sb.Append("<mark>").Append(WebUtility.HtmlEncode(text.Substring(idx, term.Length))).Append("</mark>");
            i = idx + term.Length;
        }
        return (MarkupString)sb.ToString();
    }

    private void StartEdit(string key)
    {
        _editing = key;
        _focusNext = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusNext)
        {
            _focusNext = false;
            try { await _editRef.FocusAsync(); } catch { /* ref gone */ }
        }
    }

    // open the Server tab and auto-detect the diff on first visit, so counts show without a click
    private async Task ShowServer()
    {
        _tab = Tab.Server;
        if (ServerReady && !_diffedOnce)
        {
            _diffedOnce = true;
            await Run(CheckDiff);
        }
    }

    protected override void OnInitialized()
    {
        Logger.OnLog += AppendLog;
        ScanLocal();
    }

    private bool _diffedOnce;

    private void Save()
    {
        try { Service.Save(); }
        catch (Exception ex) { AppendLog(new LogEntry($"Save failed: {ex.Message}\n", ConsoleColor.Red)); }
    }

    private void Assign(string file)
    {
        if (_assign.TryGetValue(file, out var id) && !string.IsNullOrWhiteSpace(id))
        {
            Service.Assign(file, id);
            _ = _assign.Remove(file);
            Save();
        }
    }

    private void Delete(Mod mod)
    {
        Service.Delete(mod);
        Save();
    }

    private void SetWorks(Mod mod, bool value)
    {
        mod.Works = value;
        Save();
    }

    private void SetConfigured(Mod mod, bool value)
    {
        mod.Configured = value;
        Save();
    }

    private async Task Run(Action action)
    {
        _busy = true;
        try { await Task.Run(action); }
        finally { _busy = false; await InvokeAsync(StateHasChanged); }
    }

    // local scan, then check the server so the diff counts are always current
    private Task Refresh() => Run(() => { ScanLocal(); CheckDiff(); });

    private void ScanLocal()
    {
        try { Service.Refresh(); }
        catch (Exception ex) { AppendLog(new LogEntry($"Load failed: {ex.Message}\n", ConsoleColor.Red)); }
    }

    // one button: push every folder to the server with live progress, then refresh the diff counts
    private async Task Sync()
    {
        // Progress<T> captures this UI context, so reports marshal back and re-render automatically
        var reporter = new Progress<SyncProgress>(p => { _progress = p; StateHasChanged(); });
        _progress = new SyncProgress(0, TotalDiff, "", "", DeltaKind.Add);
        try { await Run(() => { Service.SyncAll(reporter); CheckDiff(); }); }
        finally { _progress = null; await InvokeAsync(StateHasChanged); }
    }

    // compare local against the server; a failed connection is captured in the result and shown as "Off"
    private void CheckDiff()
    {
        if (!ServerReady) { _sync = null; return; }
        _sync = Service.Diff();
    }

    private static string RowClass(Mod mod, bool problem)
    {
        var state = mod.Installed ? "installed" : "absent";
        return problem ? $"{state} problem" : state;
    }

    private void RenameId(Mod mod, string value)
    {
        value = value.Trim();
        if (string.IsNullOrEmpty(value) || value.Equals(mod.Id, StringComparison.Ordinal))
            return;
        if (_manual.Remove(mod.Id, out var open))
            _manual[value] = open;
        mod.Id = value;
        Save();
    }

    private void SetFileName(Mod mod, string value)
    {
        mod.FileName = value.Trim();
        Service.Recompute();
        Save();
    }

    private void SetDep(Mod mod, int index, string value)
    {
        value = value.Trim();
        if (string.IsNullOrEmpty(value))
            mod.Dependencies.RemoveAt(index);
        else
            mod.Dependencies[index] = value;
        Save();
    }

    private void RemoveDep(Mod mod, int index)
    {
        mod.Dependencies.RemoveAt(index);
        Save();
    }

    private void AddDep(Mod mod)
    {
        var value = _draftDep.GetValueOrDefault(mod.Id, "").Trim();
        if (string.IsNullOrEmpty(value))
            return;
        if (!mod.Dependencies.Contains(value, StringComparer.OrdinalIgnoreCase))
            mod.Dependencies.Add(value);
        _draftDep[mod.Id] = "";
        Save();
    }

    private void AppendLog(LogEntry entry)
    {
        _log.Add(entry);
        if (_log.Count > 1000)
            _log.RemoveRange(0, _log.Count - 1000);
        _ = InvokeAsync(StateHasChanged);
    }

    private static string Css(ConsoleColor c) => c switch
    {
        ConsoleColor.Red or ConsoleColor.DarkRed => "#e05555",
        ConsoleColor.Green or ConsoleColor.DarkGreen => "#3fb950",
        ConsoleColor.Yellow or ConsoleColor.DarkYellow => "#d98c2b",
        ConsoleColor.Magenta or ConsoleColor.DarkMagenta => "#c678dd",
        ConsoleColor.DarkGray or ConsoleColor.Gray => "#888",
        _ => "#ddd",
    };

    public void Dispose() => Logger.OnLog -= AppendLog;
}
